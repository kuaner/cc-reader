{
  "name": "ccreader-timeline-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.preview.config.ts",
    "dev": "vite build --watch",
    "dev:shell": "vite build --watch",
    "dev:preview": "vite build --watch --config vite.preview.config.ts",
    "dev:all": "concurrently -n shell,preview -c blue,magenta \"npm run dev:shell\" \"npm run dev:preview\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.2"
  }
}
