{
  "name": "ccreader-timeline-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.preview.config.ts",
    "dev": "vite build --watch",
    "dev:shell": "vite build --watch",
    "dev:preview": "vite build --watch --config vite.preview.config.ts",
    "dev:all": "concurrently -n shell,preview -c blue,magenta \"npm run dev:shell\" \"npm run dev:preview\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "svelte": "^5.55.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
