{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vite.preview.config.ts", "vite.build.shared.ts", "vitest.config.ts"]
}
